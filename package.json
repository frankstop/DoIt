{
  "name": "do-it-desktop",
  "version": "1.0.0",
  "description": "A private desktop command center for everyday life administration.",
  "main": "dist-electron/main/main.js",
  "author": "DO IT.",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"wait-on dist-electron/main/main.js http://localhost:5173 && electron .\"",
    "build": "tsc -p tsconfig.main.json && tsc --noEmit && vite build",
    "package": "npm run build && electron-builder",
    "package:dir": "npm run build && electron-builder --dir",
    "preview": "vite preview",
    "release:check": "node scripts/check-release.cjs"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.doit.lifeadmin",
    "productName": "DO IT.",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "DoIt-${version}-${os}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  }
}
